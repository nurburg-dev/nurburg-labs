{
  "name": "airline-2-service",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "PORT=5000 MYSQL_HOST=mysql-airline2 MYSQL_PORT=3306 MYSQL_USER=user MYSQL_PASSWORD=password MYSQL_DATABASE=airline2db KAFKA_BROKERS=kafka:9092 ts-node src/index.ts",
    "mysql": "mysql -h mysql-airline2 -u user -ppassword --skip-ssl airline2db"
  },
  "dependencies": {
    "express": "^4.18.2",
    "nurburg-libs": "^0.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
